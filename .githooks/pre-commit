#!/bin/sh

set -e

echo "Running pre-commit checks..."

# ESLint
echo "→ Running ESLint..."
bun run lint

# Prettier
echo "→ Running Prettier..."
bun run format

# TypeScript
echo "→ Running TypeScript type check..."
bun run typecheck

# Tests
echo "→ Running unit tests..."
bun run test:unit

# Build
echo "→ Running build..."
bun run build

# Audit
echo "→ Running dependency audit..."
bun audit || echo "⚠ bun audit failed or unavailable, skipping"

echo "✓ All pre-commit checks passed!"
