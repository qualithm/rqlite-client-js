{
  "name": "@qualithm/rqlite-client",
  "version": "0.1.0",
  "description": "Native rqlite client for JavaScript and TypeScript runtimes.",
  "private": false,
  "type": "module",
  "keywords": [
    "rqlite",
    "sqlite",
    "database",
    "sql",
    "distributed",
    "typescript"
  ],
  "sideEffects": false,
  "license": "Apache-2.0",
  "author": "Qualithm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qualithm/rqlite-client-js.git"
  },
  "homepage": "https://github.com/qualithm/rqlite-client-js#readme",
  "bugs": {
    "url": "https://github.com/qualithm/rqlite-client-js/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "deno": "./dist/index.js",
      "node": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "bun": "./dist/testing/index.js",
      "deno": "./dist/testing/index.js",
      "node": "./dist/testing/index.js",
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "bench": "bun run bench/index.ts",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "demo": "bun run scripts/demo.ts",
    "dev": "bun --watch run src/index.ts",
    "docs": "typedoc",
    "format:fix": "prettier --write .",
    "format": "prettier --check .",
    "lint:fix": "eslint --fix .",
    "lint": "eslint .",
    "prepublishOnly": "bun run clean && bun run build",
    "start": "bun run src/index.ts",
    "test:coverage": "vitest run --coverage",
    "test:coverage:unit": "vitest run --coverage src/__tests__/unit",
    "test:integration": "vitest run src/__tests__/integration",
    "test:unit": "vitest run src/__tests__/unit",
    "test:watch": "vitest",
    "test": "vitest run src/__tests__/unit",
    "typecheck": "tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.9",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "10.0.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.3.0",
    "jiti": "2.6.1",
    "prettier": "3.8.1",
    "typedoc": "0.28.17",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "minimatch": "10.2.3"
  }
}
